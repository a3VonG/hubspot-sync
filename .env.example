# HubSpot API credentials
# Create a private app in HubSpot with the following scopes:
# - crm.objects.contacts.read
# - crm.objects.contacts.write
# - crm.objects.companies.read
# - crm.objects.companies.write
# - crm.schemas.custom.read (for custom properties)
# Note: Task access (for creating review tasks) is typically included with
# Sales Hub. If tasks scope isn't visible in the UI, it may still work -
# test with: curl -H "Authorization: Bearer TOKEN" "https://api.hubapi.com/crm/v3/objects/tasks?limit=1"
HUBSPOT_API_KEY=
CLAY_URL_IS_DENTAL_LAB=
NGROK_AUTHTOKEN=
# Custom property name for storing platform org ID on companies
# Default: platform_org_id
HUBSPOT_PLATFORM_ORG_ID_PROPERTY=platform_organization_id

# Platform database connection
# The database is accessed via SSH tunnel for security
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_NAME=platform
DB_USER=db_username
DB_PASSWORD=db_password

# SSH tunnel configuration
SSH_HOST=bastion.example.com
SSH_USER=ssh_username

# SSH private key - choose one of these options:
# Option 1: File path
SSH_KEY_PATH=~/.ssh/id_rsa
# Option 2: 1Password CLI reference (requires `op` CLI installed and signed in)
# SSH_KEY_PATH=op://vault/item/private key
# Option 3: Base64 encoded key (for CI/CD)
# SSH_KEY_BASE64=LS0tLS1CRUdJTi...

# Paddle API credentials (optional - for enrichment)
# PADDLE_API_KEY=your-paddle-api-key
# PADDLE_VENDOR_ID=your-paddle-vendor-id

# Slack webhook URL for notifications (optional)
# Create an incoming webhook at https://api.slack.com/apps
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Auto-link confidence threshold (0.0 to 1.0)
# Organizations matched with confidence above this will be auto-linked
# Default: 0.8
AUTO_LINK_CONFIDENCE_THRESHOLD=0.8

# Auto-create companies for unmatched organizations
# When enabled, creates placeholder companies for orgs without a HubSpot match
# Placeholders are named: [placeholder company from "admin@email.com"]
# When Paddle data becomes available, placeholders are enriched with real company names
# Default: false
AUTO_CREATE_COMPANIES=false

# Property name for tracking company source (auto_created, enriched_from_paddle, manual)
# Create this as a dropdown property in HubSpot
# Default: platform_has_used_prodcut
COMPANY_SOURCE_PROPERTY=platform_company_source

# HubSpot task queue ID for sync review tasks
# Tasks (conflicts, multiple matches, etc.) will be placed in this queue
# Find the ID: HubSpot UI > Sales > Tasks > Queue dropdown > inspect element > data-option-value
# HUBSPOT_TASK_QUEUE_ID=12345678

# Dry run mode - set to "true" to preview changes without making them
# Note: For blacklisting orgs/emails, edit filter_config.py instead of env vars
DRY_RUN=false

# Usercheck API key (for email qualification — disposable/public domain detection)
# Sign up at: https://app.usercheck.com/register
# USERCHECK_API_KEY=your-usercheck-api-key

# --- Outbound Lead Generation ---

# Anthropic API key (required for outbound agent)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Custom Search (required for --method search)
# Create at: https://console.cloud.google.com/ (enable Custom Search API)
# GOOGLE_API_KEY=AIza...
# Create a search engine at: https://cse.google.com/
# GOOGLE_CX=abc123...

# Override the default model (optional, default: claude-sonnet-4-20250514)
# OUTBOUND_MODEL=claude-sonnet-4-20250514
